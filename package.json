{
  "name": "vue-vaul",
  "version": "1.1.1",
  "description": "A drawer component for Vue",
  "author": "David Bender <https://github.com/dbzx10299>",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "drawer",
    "dialog",
    "modal"
  ],
  "homepage": "https://github.com/dbzx10299/vue-vaul#readme",
  "bugs": {
    "url": "https://github.com/dbzx10299/vue-vaul/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbzx10299/vue-vaul.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsdown/css": "^0.21.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.0",
    "bumpp": "^11.0.1",
    "geist-vaul": "^1.0.7",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "unplugin-vue": "^7.1.1",
    "vite": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "reka-ui": "^2.9.2",
    "vue-remove-scroll": "^1.0.2"
  }
}
